{
  "redirects": [
    {
      "source": "/admin",
      "destination": "/api/admin/auth",
      "permanent": false
    },
    {
      "source": "/llm.txt",
      "destination": "/llms.txt",
      "permanent": true
    },
    {
      "source": "/premium/:path*",
      "destination": "/curso",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|admin/|admin$).*)",
      "destination": "/spa.html"
    }
  ],
  "functions": {
    "api/checkout.ts": {
      "maxDuration": 10
    },
    "api/stripe-webhook.ts": {
      "maxDuration": 30
    },
    "api/admin/auth.ts": {
      "maxDuration": 5
    },
    "api/admin/metrics.ts": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/premium/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    }
  ]
}